<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html b:css="false" b:js="false" b:defaultwidgetversion="2" b:layoutsVersion="3" expr:dir="data:blog.languageDirection" expr:lang="data:blog.locale">
<head>
  <meta expr:charset="data:blog.encoding"/>
  <meta content="width=device-width,initial-scale=1" name="viewport"/>
  <title>@attr</title>
  <link expr:href="data:blog.blogspotFaviconUrl" rel="icon" type="image/x-icon"/>
  <b:skin><![CDATA[
    /* Demo */
    * { margin: 0 }
    body {
      background-color: #fff;
      padding: 2rem;
    }

    /*Test*/
    .table {
      border-collapse: collapse;
      font: 14px monospace;
    }

    .table :where(th, td) {
      padding: .35rem .6rem;
      border: 1px solid #ccc;
      text-align: left;
    }
  ]]></b:skin>
  <b:defaultmarkups>
    <b:defaultmarkup type="Common">
      <b:includable id='@attr'>
        <b:comment>
        Add or remove multiple attributes
        @author zkreations
        @param {Array[Array]} data - Array of attribute name-value pairs
        </b:comment>
        <b:if cond='data:'>
          <b:loop values='data:' var='i'>
            <b:attr expr:name='data:i[0]' expr:value='data:i[1]'/>
          </b:loop>
        <b:else/>
          <b:comment render='true'>Parameter [data] is required.</b:comment>
        </b:if>
      </b:includable>
    </b:defaultmarkup>
  </b:defaultmarkups>
</head>
<body>
  <b:section cond='data:view.isLayoutMode' id='main'/>
  <article class='demo'>
    <b:include data='{["id","foo"],["class","foo"]}' name='@attr'/>
    <table class='table'>
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody/>
    </table>
  </article>

  <script>
  //<![CDATA[
    document.querySelector('tbody')
      .innerHTML = [...document.querySelector('article').attributes].map(a => `<tr><td>${a.name}</td><td>${a.value}</td></tr>`).join('');
  //]]>
  </script>
</body>
</html>
