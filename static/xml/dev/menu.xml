<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:defaultwidgetversion='2' b:js='true' b:layoutsVersion='3' expr:dir='data:blog.languageDirection' expr:lang='data:blog.locale' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
  <meta expr:charset='data:blog.encoding'/>
  <meta content='width=device-width,initial-scale=1' name='viewport'/>
  <title>@menu</title>
  <link expr:href='data:blog.blogspotFaviconUrl' rel='icon' type='image/x-icon'/>
  <b:skin><![CDATA[
    /* Demo */
    * { margin: 0 }
    body {
      background-color: #fff;
      padding: 2rem;
    }

    ul,
    ol,
    ul li,
    ol li { list-style: none }

    /*Test*/
    .nav {
      padding: 0;
    }
  ]]></b:skin>
  <b:defaultmarkups>
    <b:defaultmarkup type='Common'>
      <b:includable id='@menu'>
        <b:comment>
        Create a menu from a list of links
        @author zkreations
        @param {array} links - Array of links
        @param {string} [prefix="__"] - Prefix for filter links
        @param {string} [id] - Id for the menu
        @param {string} [class] - Class for the menu
        @param {String} [itemClass] - Base class for the items (li)
        @param {String} [subnavClass] - Class for the nested submenus (ul)
        @param {String} [linkClass] - Base class for the anchors (a)
        @param {String} [hereClass] - State class when the link matches the current URL
        @param {String} [externalClass] - State class for external references
        </b:comment>
        <b:with value='data:prefix ?: "__"' var='prefix'>
          <b:if cond='data:links[0].title contains data:prefix'>
            <b:comment render='true'>The first element can't have the prefix</b:comment>
          <b:elseif cond='data:links any (l => l.title + 0 == l.title)'/>
            <b:comment render='true'>The element can't be a number</b:comment>
          <b:elseif cond='!data:links.any'/>
            <b:comment render='true'>The array can't be empty</b:comment>
          <b:else/>
            <ul class='nav'>
              <b:class cond='data:class' expr:name='data:class'/>
              <b:attr name='id' expr:value='data:id'/>
              <b:loop index='i' values='data:links' var='link'>
                <b:with value='{
                  current: (data:link.title contains data:prefix),
                  next: (data:links[data:i + 1].title contains data:prefix)
                }' var='state'>
                  <b:with value='{
                    start: (data:state.next and !data:state.current),
                    end: (!data:state.next and data:state.current)
                  }' var='menu'>
                    <b:eval expr='"&lt;li class=\"nav-item " + (data:menu.start ? "has-subnav " : "") + data:itemClass + "\">"'/>
                    <a class='nav-link' expr:href='data:link.href'>
                      <b:class cond='data:linkClass' expr:name='data:linkClass'/>
                      <b:if cond='data:link.isCurrentPage or data:view.url.canonical == data:link.href'>
                        <b:class name='is-here'/>
                        <b:class cond='data:hereClass' expr:name='data:hereClass'/>
                      </b:if>
                      <b:if cond='data:link.href contains "?ref="'>
                        <b:class name='is-external'/>
                        <b:class cond='data:externalClass' expr:name='data:externalClass'/>
                        <b:attr name='target' value='_blank'/>
                        <b:attr name='rel' value='noopener noreferrer'/>
                      </b:if>
                      <data:link.title/>
                    </a>
                    <b:eval expr='data:menu.end ? "&lt;/li>&lt;/ul>" : ""'/>
                    <b:eval expr='data:menu.start ? "&lt;ul class=\"nav-subnav " + data:subnavClass + " \">" : "&lt;/li>"'/>
                  </b:with>
                </b:with>
              </b:loop>
            </ul>
          </b:if>
        </b:with>
      </b:includable>
    </b:defaultmarkup>
    <b:defaultmarkup type="PageList">
      <b:includable id="main"/>
      <b:includable id="content"/>
      <b:includable id="overflowButton"/>
      <b:includable id="overflowablePageList"/>
      <b:includable id="pageLink"/>
      <b:includable id="pageList"/>
    </b:defaultmarkup>
  </b:defaultmarkups>
</head>
<body>
  <b:section id='main'>
    <b:widget id='PageList1' locked='true' title='Menu desplegable' type='PageList'>
      <b:widget-settings>
        <b:widget-setting name='pageListJson'><![CDATA[
          {
            "link0": {
              "href": "#url",
              "position": 0,
              "title": "Elemento 1"
            },
            "link1": {
              "href": "#url",
              "position": 1,
              "title": "Elemento 2"
            },
            "link2": {
              "href": "",
              "position": 2,
              "title": "__Elemento 2.1"
            },
            "link3": {
              "href": "#url",
              "position": 3,
              "title": "__Elemento 2.2"
            },
            "link4": {
              "href": "#url",
              "position": 4,
              "title": "Elemento 3"
            },
            "link5": {
              "href": "#url",
              "position": 5,
              "title": "Elemento 4"
            },
            "link6": {
              "href": "#url",
              "position": 6,
              "title": "__Elemento 4.1"
            },
            "link7": {
              "href": "#url",
              "position": 7,
              "title": "__Elemento 4.2"
            },
            "link8": {
              "href": "#url",
              "position": 8,
              "title": "Elemento 5"
            },
            "link9": {
              "href": "https://www.zkreations.com?ref=external",
              "position": 9,
              "title": "External Link"
            }
          }
        ]]></b:widget-setting>
      </b:widget-settings>
      <b:includable id='main'>
        <div class='nav-example'>
          <b:include name='@menu' data='{ links: data:links, itemClass: "bg-slate-100" }'/>
        </div>
      </b:includable>
    </b:widget>
  </b:section>
  <!-- Quita los guiones bajos del texto de los enlaces -->
  <script>
  //<![CDATA[
    document.querySelectorAll('.nav-subnav .nav-link').forEach(link => {
      link.textContent = link.textContent.trim().replace(/^_+/, '')
    })
  //]]>
  </script>
</body>
</html>
